<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Style Selector="TextBox.ModernInput">
        <Setter Property="Background" Value="#2C2C2E"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="MinHeight" Value="45"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="12,0"/>
    </Style>
        
    <Style Selector="TextBox.ModernInput:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="#1c1f24"/>
    </Style>
        
    <Style Selector="TextBox.ModernInput:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="#16191d"/>
        <Setter Property="BorderBrush" Value="#7B78FF"/>
    </Style>
        
    <Style Selector="TextBox.ModernInput:focus">
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style Selector="Button.PrimaryButton">
        <Setter Property="Background" Value="#007AFF"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.PrimaryButton:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#0056B3"/>
        <Setter Property="Opacity" Value="0.8"/>
    </Style>
    
    <Style Selector="Button.PrimaryButton:disabled /template/ ContentPresenter">
        <Setter Property="Background" Value="#3A3A3C" />
        <Setter Property="Foreground" Value="#8E8E93" />
        <Setter Property="Opacity" Value="0.6" /> 
    </Style>
    
    <Style Selector="ComboBox.ModernCombo">
        <Setter Property="Background" Value="#2C2C2E" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="MinHeight" Value="45" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    
    <Style Selector="ComboBox.ModernCombo:focus /template/ Border#Background">
        <Setter Property="BorderBrush" Value="#7B78FF"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="ComboBox.ModernCombo ComboBoxItem">
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Background" Value="#2C2C2E"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    
    <Style Selector="ComboBox.ModernCombo /template/ Popup Border">
        <Setter Property="Background" Value="#2C2C2E" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="BorderBrush" Value="#3A3A3C" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="ComboBox.ModernCombo ComboBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#3A3A3C" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="ComboBox.ModernCombo ComboBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#7B78FF" />
        <Setter Property="Foreground" Value="White" />
    </Style>
    
    <Style Selector="NumericUpDown.ModernNumeric">
        <Setter Property="Background" Value="#2C2C2E" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="MinHeight" Value="45" />
        <Setter Property="ShowButtonSpinner" Value="False" />
    </Style>
    
    <Style Selector="NumericUpDown.ModernNumeric /template/ TextBox#PART_TextBox">
        <Setter Property="Background" Value="#2C2C2E" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    
    <Style Selector="NumericUpDown.ModernNumeric /template/ TextBox#PART_TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="#16191d" />
        <Setter Property="BorderBrush" Value="#7B78FF" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="NumericUpDown.ModernNumeric /template/ TextBox#PART_TextBox:focus">
        <Setter Property="Foreground" Value="White" />
    </Style>
</Styles>
