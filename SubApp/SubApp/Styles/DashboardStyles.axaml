<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Border.HeaderCard">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#1a1e24" Offset="0" />
                <GradientStop Color="#2b2e33" Offset="1" />
            </LinearGradientBrush>
        </Setter>
        <Setter Property="BorderBrush" Value="#383d44" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="BoxShadow" Value="0 4 20 0 #40000000" />
        <Setter Property="Padding" Value="0,16" />
    </Style>
    <Style Selector="Button.icon-button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

</Styles>
