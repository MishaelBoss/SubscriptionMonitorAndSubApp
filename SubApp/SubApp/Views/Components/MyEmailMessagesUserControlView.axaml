<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SubApp.ViewModels.Components"
             x:DataType="vm:MyEmailMessagesUserControlViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SubApp.Views.Components.MyEmailMessagesUserControlView">
    
    <UserControl.Styles>
        <StyleInclude Source="/Styles/EmailStyles.axaml"/>
    </UserControl.Styles>
    
    <ScrollViewer>
        <ItemsControl ItemsSource="{Binding Emails}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#1E1E1E" CornerRadius="12" Margin="5" Padding="15">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="{Binding FromEmail}" FontWeight="Bold" FontSize="16" Foreground="White"/>
                                <TextBlock Text="{Binding Subject}" FontSize="14" Foreground="#AAAAAA" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding ReceivedDate}" FontSize="12" Foreground="#666666" Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="5">
                                    <TextBlock Text="{Binding Amount, StringFormat='{}{0:N2}'}" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding Currency}" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                                </StackPanel>
                                <Border Classes="Status Processed" Margin="0,8,0,0">
                                    <TextBlock Text="Обработано" Foreground="White" FontSize="11"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
