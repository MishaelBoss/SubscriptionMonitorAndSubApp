<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:vm="using:SubApp.ViewModels.Components"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:DashboardUserControlViewModel"
             x:Class="SubApp.Views.Components.DashboardUserControl">

    <UserControl.Styles>
		<StyleInclude Source="/Styles/DashboardStyles.axaml"/>
	</UserControl.Styles>

    <Border VerticalAlignment="Top" 
            HorizontalAlignment="Stretch"
            Height="50"
            Margin="10,10,10,0"
            Padding="15,0"
            CornerRadius="8"
            ZIndex="1">
        <Grid ColumnDefinitions="*, Auto">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <PathIcon Data="M3,5H21A2,2 0 0,1 23,7V17A2,2 0 0,1 21,19H3A2,2 0 0,1 1,17V7A2,2 0 0,1 3,5M3,11V17H21V11H3M3,7V9H21V7H3M4,12H6V14H4V12Z" 
                          Foreground="#7B78FF" 
                          Width="18" Height="18"/>
    
                <TextBlock Text="Монитор Подписок" 
                           Foreground="#7B78FF" 
                           FontSize="16" 
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button Background="Transparent" BorderThickness="0" Padding="5" Command="{Binding OpenProfileCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="admin" VerticalAlignment="Center" Foreground="White"/>
                        <Ellipse Width="32" Height="32" Fill="#7B78FF"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
