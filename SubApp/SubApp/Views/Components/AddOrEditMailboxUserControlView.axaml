<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:vm="using:SubApp.ViewModels.Components"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:AddOrEditMailboxUserControlViewModel"
             Background="#0a0c0f"
             x:Class="SubApp.Views.Components.AddOrEditMailboxUserControlView">
    
    <UserControl.Styles>
        <StyleInclude Source="/Styles/ModernStyles.axaml"/>
        <StyleInclude Source="/Styles/ButtonsStyles.axaml"/>
    </UserControl.Styles>
    
    <ScrollViewer>
        <Grid RowDefinitions="Auto,*">
            <Grid Grid.Row="0">
                <Button Background="Transparent" 
                        BorderThickness="0" 
                        Padding="5" 
                        Margin="10,0,0,0"
                        Command="{Binding CloseCommand}">
                    <Image Source="/Assets/back-64.png" Width="32" Height="32"/>
                </Button>
            </Grid>

            <Grid Grid.Row="1">
                <StackPanel Margin="16" Spacing="20">
                    <Border Background="#1C1C1E" CornerRadius="12" Padding="16">
                        <StackPanel Spacing="15">
                            <StackPanel Spacing="5">
                                <TextBlock Text="EMAIL АДРЕС" FontSize="11" FontWeight="Bold" Foreground="#8E8E93"/>
                                <TextBox Text="{Binding Email}" 
                                         Classes="ModernInput"
                                         InputMethod.IsInputMethodEnabled="True"/>
                            </StackPanel>

                            <StackPanel Spacing="5">
                                <TextBlock Text="ПАРОЛЬ ОТ ПОЧТЫ" FontSize="11" FontWeight="Bold" Foreground="#8E8E93"/>
                                <TextBox PasswordChar="●" Text="{Binding Password}" 
                                         Classes="ModernInput"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#1C1C1E" CornerRadius="12" Padding="16">
                        <StackPanel Spacing="15">
                            <StackPanel Spacing="5">
                                <TextBlock Text="ПОЧТОВЫЙ ПРОВАЙДЕР" FontSize="11" FontWeight="Bold" Foreground="#8E8E93" />
                                <ComboBox HorizontalAlignment="Stretch" 
                                          Classes="ModernCombo"
                                          ItemsSource="{Binding MailProviders}"
                                          SelectedItem="{Binding SelectedProvider}"/>
                            </StackPanel>

                            <Grid ColumnDefinitions="*, 100" ColumnSpacing="12">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="IMAP СЕРВЕР" FontSize="11" FontWeight="Bold" Foreground="#8E8E93"/>
                                    <TextBox Text="{Binding ImapServer}" 
                                             Classes="ModernInput"
                                             InputMethod.IsInputMethodEnabled="True"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="5">
                                    <TextBlock Text="ПОРТ" FontSize="11" FontWeight="Bold" Foreground="#8E8E93"/>
                                    <NumericUpDown Value="{Binding ImapPort, TargetNullValue=0}" 
                                                   Minimum="1" 
                                                   Maximum="65535" 
                                                   Increment="1"
                                                   FormatString="0"
                                                   ShowButtonSpinner="False"
                                                   Classes="ModernNumeric"
                                                   InputMethod.IsInputMethodEnabled="True"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="5">
                                <TextBlock Text="ЧАСТОТА ПРОВЕРКИ (МИН)" FontSize="11" FontWeight="Bold" Foreground="#8E8E93"/>
                                <NumericUpDown Value="{Binding FrequencyCheck, TargetNullValue=0}" 
                                               Minimum="1" 
                                               Maximum="1440" 
                                               ShowButtonSpinner="False"
                                               Classes="ModernNumeric"
                                               InputMethod.IsInputMethodEnabled="True"/>
                            </StackPanel>

                            <CheckBox IsChecked="{Binding AutoCheck}" Margin="0,5">
                                <TextBlock Text="Автоматическая проверка" 
                                           Foreground="#8E8E93" 
                                           FontSize="13"/>
                            </CheckBox>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{Binding ErrorEmail}" 
                               Foreground="#FF5252" 
                               FontSize="12" 
                               HorizontalAlignment="Center"
                               IsVisible="{Binding ErrorEmail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                    <Button Classes="PrimaryButton" 
                            Content="{Binding ConfirmButtonText}" 
                            HorizontalAlignment="Stretch" 
                            IsEnabled="{Binding IsActiveConfirmButton}" 
                            Command="{Binding SaveEmailCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
