<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:vm="using:SubApp.ViewModels.Pages"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:EmailsUserControlViewModel"
             x:Class="SubApp.Views.Pages.EmailsUserControlView">
    
    <UserControl.Styles>
        <StyleInclude Source="/Styles/EmailsStyles.axaml"/>
    </UserControl.Styles>
    
     <ScrollViewer>
        <StackPanel Margin="12" Spacing="15">
            <Border Classes="ContentCard">
                <StackPanel Spacing="10">
                    <TextBlock Text="Подключенные почтовые ящики" Classes="SectionHeader"/>
                    <Separator Background="#2C2C2E" Height="1"/>
                    
                    <ItemsControl ItemsSource="{Binding CartMailboxesViewModels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="18" Padding="15" Margin="0,5">
                                    <StackPanel Spacing="12">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBlock Text="{Binding Email}" 
                                                       FontWeight="Bold" 
                                                       FontSize="16" 
                                                       Foreground="Black" />
                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding LastCheck}" 
                                                       Foreground="#8E8E93" 
                                                       FontSize="12" />
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Background="#4A90E2" CornerRadius="6" Padding="8,3">
                                                <TextBlock Text="{Binding Provider}" FontSize="11" Foreground="White" />
                                            </Border>
                                            <Border Background="#00C7AC" CornerRadius="6" Padding="8,3">
                                                <TextBlock Text="{Binding Status}" FontSize="11" Foreground="White" />
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Button Classes="ActionButton Start" Width="45" Height="35" Command="{Binding RunCommand}">
                                                <Image Source="/Assets/play-64.png" Width="14" Height="14"/>
                                            </Button>
                                            
                                            <Button Classes="ActionButton Fast" Width="45" Height="35" Command="{Binding FustRunCommand}">
                                                <Image Source="/Assets/fust-play-64.png" Width="14" Height="14"/>
                                            </Button>

                                            <Button Classes="IconButton Edit" Width="45" Height="35" Command="{Binding OpenEditEmailCommand}">
                                                <Image Source="/Assets/edit-64.png" Width="14" Height="14"/>
                                            </Button>

                                            <Button Classes="IconButton Delete" Width="45" Height="35" Command="{Binding OpenDeleteEmailCommand}">
                                                <Image Source="/Assets/trash-64.png" Width="14" Height="14"/>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button HorizontalAlignment="Center" Margin="0,10,0,5" Classes="AddButton" Command="{Binding OpenAddEmailCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Image Source="/Assets/add-white-64.png" Width="18"/>
                            <TextBlock Text="Добавить почту" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
