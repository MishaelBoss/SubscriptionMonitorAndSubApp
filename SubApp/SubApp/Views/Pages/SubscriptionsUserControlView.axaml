<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:vm="using:SubApp.ViewModels.Pages"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:SubApp.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:SubscriptionsUserControlViewModel"
             x:Class="SubApp.Views.Pages.SubscriptionsUserControlView">
    
    <UserControl.Styles>
        <StyleInclude Source="/Styles/SubscriptionsStyles.axaml"/>
    </UserControl.Styles>
    
    <UserControl.Resources>
        <converters:EnumToRussianConverter x:Key="EnumToRussianConverter"/>
        <converters:OverdueColorConverter x:Key="OverdueColorConverter"/>
    </UserControl.Resources>
    
    <Border Padding="15">
        <Grid RowDefinitions="Auto,*">
            <Grid Grid.Row="0">
                <ComboBox HorizontalAlignment="Stretch" 
                          Classes="ModernCombo"
                          ItemsSource="{Binding Status}"
                          SelectedItem="{Binding SelectedStatus}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumToRussianConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <Grid Grid.Row="1">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Subscriptions}" Background="Transparent">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0, 10 , 0 ,10" 
                                        Padding="16" 
                                        Background="#1E1E22" 
                                        CornerRadius="12" 
                                        BorderBrush="{Binding IsOverdue, Converter={StaticResource OverdueColorConverter}}" 
                                        BorderThickness="1.5"
                                        MaxWidth="400">
                                    <StackPanel Spacing="12">
                                        
                                        <Border HorizontalAlignment="Left" 
                                                Background="#FF4B55" 
                                                CornerRadius="15" 
                                                Padding="8,4"
                                                IsVisible="{Binding IsOverdue}">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <Image Source="/Assets/warning-64.png" Width="24"/>
                                                <TextBlock Text="ПРОСРОЧЕНА"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="12" 
                                                           FontWeight="Bold" 
                                                           Foreground="White"/>
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Service.Name}" 
                                                       Foreground="#444" 
                                                       FontSize="14"
                                                       MaxWidth="200"
                                                       TextTrimming="CharacterEllipsis"
                                                       HorizontalAlignment="Left"/>
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <TextBlock Text="{Binding Amount, StringFormat='{}{0:N2}'}" 
                                                           Foreground="White" 
                                                           FontSize="24" 
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Currency}" 
                                                           FontSize="24" 
                                                           Foreground="White"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding BillingCycle, Converter={StaticResource EnumToRussianConverter}}" 
                                                       Foreground="#666" 
                                                       FontSize="12"/>
                                        </StackPanel>

                                        <ProgressBar Value="100" Height="4" Background="#333" Foreground="#8A75FF"/>

                                        <Border Background="#2A1B1D" 
                                                BorderBrush="#FF4B55" 
                                                BorderThickness="1" 
                                                CornerRadius="8" 
                                                Padding="12"
                                                IsVisible="{Binding IsOverdue}">
                                            <StackPanel Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="⚠️ ПРОСРОЧКА!" Foreground="White" FontWeight="Bold"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding OverdueDays, StringFormat='Просрочена на {0} дн.'}" Foreground="White" Opacity="0.8"/>
                                            </StackPanel>
                                        </Border>

                                        <Button HorizontalAlignment="Stretch" 
                                                HorizontalContentAlignment="Center"
                                                Background="Transparent" 
                                                BorderBrush="#8A75FF" 
                                                BorderThickness="1" 
                                                CornerRadius="8"
                                                Padding="10"
                                                Command="{Binding $parent[ItemsControl].((vm:SubscriptionsUserControlViewModel)DataContext).OpenDetailsCommand}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Image Source="/Assets/eye-64.png" Width="16"/>
                                                <TextBlock Text="Подробнее" Foreground="#8A75FF"/>
                                            </StackPanel>
                                        </Button>
                                        
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</UserControl>
