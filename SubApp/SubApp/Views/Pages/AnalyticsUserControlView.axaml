<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:vm="using:SubApp.ViewModels.Pages"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:AnalyticsUserControlViewModel"
             x:Class="SubApp.Views.Pages.AnalyticsUserControlView">
    
    <UserControl.Styles>
        <StyleInclude Source="/Styles/ContentCardStyles.axaml"/>
    </UserControl.Styles>
    
    <ScrollViewer>
        <StackPanel Margin="12" Spacing="15">
            
            <Border Classes="ContentCard">
                <StackPanel Spacing="10">
                    <TextBlock Text="Статистика по подпискам" Classes="SectionHeader"/>
                    <Separator Background="#2C2C2E" Height="1"/>
                    
                    <UniformGrid Columns="2" RowSpacing="8" ColumnSpacing="8">
                        <Border Classes="StatCard">
                            <StackPanel>
                                <TextBlock Text="ВСЕГО ПОДПИСОК" Classes="CardHeader"/>
                                <TextBlock Text="{Binding CountSubscription}" Classes="CardValue"/>
                            </StackPanel>
                        </Border>
                        <Border Classes="StatCard">
                            <StackPanel>
                                <TextBlock Text="АКТИВНЫХ ПОДПИСОК" Classes="CardHeader"/>
                                <TextBlock Text="{Binding CountActiveSubscription}" Classes="CardValue"/>
                            </StackPanel>
                        </Border>
                        <Border Classes="StatCard">
                            <StackPanel>
                                <TextBlock Text="РАСХОДЫ В МЕСЯЦ" Classes="CardHeader"/>
                                <TextBlock Text="{Binding TotalMonthlyCost, StringFormat='{}{0:N0} ₽'}" Classes="CardValue"/>
                            </StackPanel>
                        </Border>
                        <Border Classes="StatCard">
                            <StackPanel>
                                <TextBlock Text="РАСХОДЫ В ГОД" Classes="CardHeader" Foreground="#FF453A"/>
                                <TextBlock Text="{Binding TotalYearlyCost, StringFormat='{}{0:N0} ₽'}" Classes="CardValue"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Classes="ContentCard">
                <StackPanel Spacing="10">
                    <TextBlock Text="Расходы по категориям" Classes="SectionHeader"/>
                    <Separator Background="#2C2C2E" Height="1"/>
                    
                    <StackPanel HorizontalAlignment="Center" Margin="0,20" Spacing="10">
                        <TextBlock Text="Нет пока данных" Foreground="#8E8E93" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
