<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:vm="using:SubApp.ViewModels.Pages"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:SubApp.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:HomeUserControlViewModel"
             x:Class="SubApp.Views.Pages.HomeUserControlView">
    
    <UserControl.Styles>
        <StyleInclude Source="/Styles/ContentCardStyles.axaml"/>
        <StyleInclude Source="/Styles/ButtonsStyles.axaml"/>
    </UserControl.Styles>
    
    <UserControl.Resources>
        <converters:NumericToBoolConverter x:Key="NumericToBoolConverter"/>
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Margin="12" Spacing="15">
            <UniformGrid Columns="2" RowSpacing="8" ColumnSpacing="8">
                <Border Classes="StatCard">
                    <StackPanel>
                        <TextBlock Text="АКТИВНЫХ ПОДПИСОК" Classes="CardHeader"/>
                        <TextBlock Text="{Binding CountSubscription}" Classes="CardValue"/>
                    </StackPanel>
                </Border>
                <Border Classes="StatCard">
                    <StackPanel>
                        <TextBlock Text="РАСХОДЫ В МЕСЯЦ" Classes="CardHeader"/>
                        <TextBlock Text="{Binding TotalMonthlyCost, StringFormat='{}{0:N0} ₽'}" Classes="CardValue"/>
                    </StackPanel>
                </Border>
                <Border Classes="StatCard">
                    <StackPanel>
                        <TextBlock Text="РАСХОДЫ В ГОД" Classes="CardHeader"/>
                        <TextBlock Text="{Binding TotalYearlyCost, StringFormat='{}{0:N0} ₽'}" Classes="CardValue"/>
                    </StackPanel>
                </Border>
                <Border Classes="StatCard">
                    <StackPanel>
                        <TextBlock Text="СКОРО СПИСАНИЕ" Classes="CardHeader" Foreground="#FF453A"/>
                        <TextBlock Text="{Binding NextPaymentSummary}" Classes="CardValue"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Classes="ContentCard">
                <StackPanel Spacing="10">
                    <TextBlock Text="Последние платежи" Classes="SectionHeader"/>
                    <Separator Background="#2C2C2E" Height="1"/>
                    
                    <ItemsControl ItemsSource="{Binding RecentPayments}">
                        <ItemsControl.ItemTemplate>
                             <DataTemplate>
                                 <Border Background="#F2F2F7" CornerRadius="10" Padding="12,8" Margin="0, 5">
                                     <Grid ColumnDefinitions="70, *, Auto, Auto">
                                         <Border Grid.Column="0" Background="#4A90E2" CornerRadius="15" Padding="8,4">
                                             <TextBlock Text="{Binding ServiceName}" 
                                                        Foreground="White" 
                                                        FontSize="12" 
                                                        FontWeight="Bold"
                                                        MaxWidth="50"
                                                        TextTrimming="CharacterEllipsis"/>
                                         </Border>
                                            
                                         <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0">
                                             <TextBlock Text="{Binding Amount, StringFormat='{}{0:N2}'}" 
                                                        FontWeight="Bold"/>
                                             <TextBlock Text="{Binding Currency}" 
                                                        Margin="5,0,0,0"/>
                                         </StackPanel>
                                            
                                         <TextBlock Grid.Column="2" Text="{Binding ReceivedDate, StringFormat='dd.MM.yyyy'}" Foreground="#8E8E93" 
                                                    VerticalAlignment="Center" Margin="0,0,10,0"/>
                                     </Grid>
                                 </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <StackPanel HorizontalAlignment="Center"
                                Margin="0,20" 
                                Spacing="10"
                                IsVisible="{Binding RecentPayments.Count, Converter={StaticResource NumericToBoolConverter}}">
                        <TextBlock Text="Нет платежей" Foreground="#8E8E93" HorizontalAlignment="Center"/>
                    </StackPanel>
                    
                    <Button HorizontalAlignment="Center" 
                            Margin="0,5" 
                            Classes="TransparentButton" 
                            Command="{Binding LoadMoreEmailsCommand}"
                            IsVisible="{Binding HasMoreDataEmail}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="Загрузаить еще"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Border Classes="ContentCard">
                <StackPanel Spacing="10">
                    <TextBlock Text="Активные подписки" Classes="SectionHeader"/>
                    <Separator Background="#2C2C2E" Height="1"/>
                    
                    <ItemsControl ItemsSource="{Binding Subscriptions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F2F2F7" CornerRadius="10" Padding="12,8" Margin="0, 5">
                                    <Grid ColumnDefinitions="70, *, Auto, Auto">
                                        <Border Grid.Column="0" Background="#4A90E2" CornerRadius="15" Padding="8,4">
                                            <TextBlock Text="{Binding Service.Name}" 
                                                       Foreground="White" 
                                                       FontSize="12" 
                                                       FontWeight="Bold"
                                                       MaxWidth="50"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                        
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0">
                                            <TextBlock Text="{Binding Amount, StringFormat='{}{0:N2}'}" 
                                                       FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Currency}" 
                                                       Margin="5,0,0,0"/>
                                        </StackPanel>
                                        
                                        <TextBlock Grid.Column="2" Text="{Binding NextPaymentDate, StringFormat='dd.MM.yyyy'}" Foreground="#8E8E93" 
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                            
                                        <Border Grid.Column="3" Background="{Binding StatusColor}" CornerRadius="10" Padding="6,2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding StatusDisplay}"
                                                       Foreground="Black" 
                                                       FontSize="11"
                                                       MaxWidth="50"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button HorizontalAlignment="Center" 
                            Margin="0,5" 
                            Classes="AddButton" 
                            Command="{Binding OpenAddSubscription}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Image Source="/Assets/add-white-64.png" Width="20"/>
                            <TextBlock Text="Добавить подписку"/>
                        </StackPanel>
                    </Button>
                    
                    <Button HorizontalAlignment="Center" 
                            Margin="0,5" 
                            Classes="TransparentButton" 
                            Command="{Binding LoadMoreSubscriptionsCommand}"
                            IsVisible="{Binding HasMoreDataSubscription}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="Загрузаить еще"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
            <Grid Height="80"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
